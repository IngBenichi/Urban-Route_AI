# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=urbanroute
POSTGRES_PASSWORD=changeme
POSTGRES_DB=urbanroutedb

# URL usada por el backend (asyncpg para runtime, psycopg2 en alembic.ini)
DATABASE_URL=postgresql+asyncpg://urbanroute:changeme@db:5432/urbanroutedb
# URL síncrona para Alembic (mismas credenciales, driver diferente)
SYNC_DATABASE_URL=postgresql://urbanroute:changeme@localhost:5432/urbanroutedb

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia-este-secreto-en-produccion-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ─── Admin credentials ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-admin-password

# ─── Grok AI (X.ai) ────────────────────────────────────────────
# Obtén tu API key en: https://console.x.ai/
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_MODEL=grok-3-mini

# ─── MapTiler (free tier: 75k tiles/mes) ───────────────────────
# Obtén tu API key en: https://cloud.maptiler.com/
MAPTILER_API_KEY=your-maptiler-api-key-here

# ─── pgAdmin ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@urbanroute.local
PGADMIN_PASSWORD=changeme

# ─── Configuración del sistema de buses ────────────────────────
BUS_AVG_SPEED_KMH=20
MAX_TRANSFER_RESULTS=5
MAX_DIRECT_RESULTS=10

# ─── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
